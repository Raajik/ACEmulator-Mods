{
  // Master toggle for call-for-help reinforcements in landscape landblocks.
  "LandscapeEnabled": true,
  // Chance (0.0–1.0) that a landscape creature calls for help on death.
  "LandscapeChance": 0.15,
  // Minimum number of reinforcements to spawn in landscape when the event triggers.
  "LandscapeSpawnMin": 1,
  // Maximum number of reinforcements to spawn in landscape when the event triggers.
  "LandscapeSpawnMax": 5,

  // Master toggle for call-for-help reinforcements in dungeons.
  "DungeonEnabled": false,
  // Chance (0.0–1.0) that a dungeon creature calls for help on death.
  "DungeonChance": 0.15,
  // Minimum number of reinforcements to spawn in dungeons when the event triggers.
  "DungeonSpawnMin": 1,
  // Maximum number of reinforcements to spawn in dungeons when the event triggers.
  "DungeonSpawnMax": 3,

  // Fraction of the original creature's max health used as a lower bound for reinforcement max health.
  "ReinforcementHealthMin": 0.3,
  // Fraction of the original creature's max health used as an upper bound for reinforcement max health.
  "ReinforcementHealthMax": 0.7,

  // Fraction of the original creature's scale used as a lower bound for reinforcement size.
  "ReinforcementScaleMin": 0.1,
  // Fraction of the original creature's scale used as an upper bound for reinforcement size.
  "ReinforcementScaleMax": 0.8,

  // Flavor messages broadcast when reinforcements are triggered. {0} is replaced with the creature's name.
  "CallForHelpMessages": [
    "The {0} cries out for help!",
    "The {0} howls for its kin!",
    "The {0} shrieks as it falls!",
    "The {0} calls to its allies!",
    "The {0} wails in desperation!",
    "The {0} roars for reinforcement!",
    "The {0} screeches a warning!",
    "The {0} bellows in rage!",
    "The {0} keens for aid!",
    "The {0} summons its brethren!",
    "The {0} yowls for backup!",
    "The {0} bleats for help!",
    "Upon seeing the {0} fall, reinforcements arrive swiftly!",
    "The fall of the {0} draws more of its kind!",
    "Reinforcements rush in as the {0} goes down!",
    "More {0} pour in to avenge their fallen!",
    "The death of the {0} has been noticed—allies close in!",
    "As the {0} falls, its kin answer the call!",
    "Reinforcements surge forward at the {0}'s demise!",
    "The {0}'s fall signals others to join the fray!",
    "New foes emerge where the {0} fell!",
    "The {0} falls—and its brethren rise to take its place!",
    "Word of the {0}'s defeat spreads; reinforcements converge!",
    "No sooner does the {0} fall than more appear!",
    "The {0} dies with a final cry—and the pack responds!",
    "Reinforcements stream in where the {0} fell!",
    "With the {0} down, its allies rush to the fight!",
    "The {0} falls; from nearby, more close in!",
    "Its death cry echoes—more {0} answer!",
    "The fall of one {0} brings others running!"
  ]
