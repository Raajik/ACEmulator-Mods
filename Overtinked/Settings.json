{
  // Maximum tinkers allowed per item (NumTimesTinkered). Recipe checks use MaxTries - 1.
  "MaxTries": 50,
  // Difficulty step added for each extra tinker tier when extending RecipeManager.TinkeringDifficulty.
  "Scale": 0.5,
  // Maximum number of imbues allowed on an item (bit-count of ImbuedEffect flags).
  "MaxImbueEffects": 5,
  // When true, uses Overtinked's custom tinkering flow for RecipeManager.UseObjectOnTarget.
  "EnableRecipeManagerPatch": true,
  // When true, failed numeric tinkers apply the opposite effect (e.g. -Damage) instead of destroying the item.
  "EnableFailureRedesign": true,
  // When true, failed imbue tinkers add +1 Workmanship (up to a cap of 10) instead of destroying the item.
  "EnableDefaultImbueFailureWorkmanship": true,
